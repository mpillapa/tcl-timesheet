# ============================================================================
# PLANTILLA de secrets.toml — NO contiene credenciales reales.
# Copia este archivo como `.streamlit/secrets.toml` y rellena con tus datos.
# El archivo real está en .gitignore y NO se sube a GitHub.
# ============================================================================

[auth]
# Control de acceso. IPs públicas estáticas que pueden entrar sin PIN.
allowed_ips = ["200.105.244.170"]
# PIN para cuando se accede desde una IP no autorizada (6+ caracteres recomendado).
pin = "PON_TU_PIN_AQUI"

[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/TU_SPREADSHEET_ID_AQUI/edit"
worksheet = "Registros"

# --- Credenciales del Service Account (JSON descargado de Google Cloud) ---
type = "service_account"
project_id = "tu-proyecto-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIEv...TODO_EL_CONTENIDO...==\n-----END PRIVATE KEY-----\n"
client_email = "marcador-horas@tu-proyecto-id.iam.gserviceaccount.com"
client_id = "000000000000000000000"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/marcador-horas%40tu-proyecto-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
